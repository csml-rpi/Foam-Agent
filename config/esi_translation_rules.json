{
  "file_maps": {
    "constant/momentumTransport": "constant/turbulenceProperties",
    "constant/physicalProperties": "constant/thermophysicalProperties"
  },
  "keyword_swaps": [
    {
      "pattern": "\\bmodel\\s+kEpsilon;",
      "replacement": "RASModel kEpsilon;"
    },
    {
      "pattern": "\\bmodel\\s+kOmegaSST;",
      "replacement": "RASModel kOmegaSST;"
    },
    {
      "pattern": "\\bmodel\\s+RNGkEpsilon;",
      "replacement": "RASModel RNGkEpsilon;"
    },
    {
      "pattern": "\\bmodel\\s+realizableKE;",
      "replacement": "RASModel realizableKE;"
    },
    {
      "pattern": "\\bapplication\\s+buoyantFoam;",
      "replacement": "application     buoyantPimpleFoam;"
    },
    {
      "pattern": "\\bhePsiThermo;",
      "replacement": "heRhoThermo;"
    },
    {
      "pattern": "\\bviscosityModel\\b",
      "replacement": "transportModel"
    }
  ],
  "blacklisted_solvers": [
    "adjointShapeOptimisationFoam",
    "boundaryFoam"
  ],
  "transient_solvers": [
    "icoFoam",
    "pisoFoam",
    "pimpleFoam",
    "rhoPimpleFoam",
    "rhoCentralFoam",
    "interFoam",
    "multiphaseInterFoam"
  ],
  "incompressible_transient_solvers": [
    "icoFoam",
    "pisoFoam"
  ],
  "solvers_using_transport_properties": [
    "icoFoam",
    "pisoFoam",
    "simpleFoam",
    "pimpleFoam"
  ],
  "chemkin_markers": [
    "Chemkin",
    "chemkin",
    "foam:chemkin"
  ],
  "pfinal_block": "\n\n    pFinal\n    {\n        $p;\n        relTol          0;\n    }",
  "pref_injection": "\n    pRefCell        0;\n    pRefValue       0;"
}
